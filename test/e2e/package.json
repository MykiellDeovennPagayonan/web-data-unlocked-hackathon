{
  "name": "e2e-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "playwright test --reporter=list",
    "test:low-io": "playwright test --reporter=list",
    "test:headed": "set E2E_HEADED=true && playwright test --headed",
    "test:debug": "set E2E_DEBUG_ARTIFACTS=true && playwright test",
    "test:ui": "playwright test --ui",
    "test:admin": "playwright test --config=playwright.admin.config.ts --reporter=list",
    "seed:social": "tsx seed/seed-social-media.ts",
    "cleanup:all": "tsx utils/cleanup.ts",
    "cleanup:admin": "tsx utils/cleanup-admin.ts",
    "demo:flow1": "E2E_DEBUG_ARTIFACTS=true E2E_HEADED=true playwright test demo/flow1-free-tier-abuser.spec.ts --headed --reporter=list",
    "demo:flow2": "E2E_DEBUG_ARTIFACTS=true E2E_HEADED=true playwright test demo/flow2-suspicious-email-block.spec.ts --headed --reporter=list",
    "demo:flow3": "E2E_DEBUG_ARTIFACTS=true E2E_HEADED=true playwright test demo/flow3-bot-scraper-attack.spec.ts --headed --reporter=list",
    "demo:flow4": "E2E_DEBUG_ARTIFACTS=true E2E_HEADED=true playwright test demo/flow4-trusted-org-certificate.spec.ts --headed --reporter=list",
    "demo:flow5": "E2E_DEBUG_ARTIFACTS=true E2E_HEADED=true playwright test demo/flow5-trusted-individual-portable-kyc.spec.ts --headed --reporter=list",
    "demo:flow45": "tsx demo-e2e-run.ts --scenario flow-4-5",
    "demo:stress": "tsx demo-e2e-run.ts --scenario abuse-stress",
    "demo:all": "tsx demo-e2e-run.ts --scenario all"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "^20",
    "bcryptjs": "2.4.3",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0",
    "prisma": "7.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/client": "7.8.0",
    "ioredis": "^5.11.0"
  }
}
